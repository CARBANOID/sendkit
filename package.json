{
  "name": "sendkit-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "dev:cli": "bun run packages/cli/src/index.ts",
    "dev:local-mcp": "bun run packages/local-mcp/src/index.ts",
    "dev:remote-mcp": "bun run apps/remote-mcp/src/index.ts",
    "build:core": "bun run --filter @carbanoid-org/sendkit-core build",
    "build:cli": "bun run --filter @carbanoid-org/sendkit build",
    "build:local-mcp": "bun run --filter @carbanoid-org/sendkit-mcp build",
    "typecheck": "tsc --noEmit",
    "release:pack:core" : "bun run --filter @carbanoid-org/sendkit-core pack:dry",
    "release:pack:cli" : "bun run --filter @carbanoid-org/sendkit pack:dry",
    "release:pack:local-mcp" : "bun run --filter @carbanoid-org/sendkit-mcp pack:dry"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}